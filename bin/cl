#!/usr/bin/env bash

set -u

CONFIG_FILE="${HOME}/.config/clusters.local"

load_local_config() {
    if [[ -r "${CONFIG_FILE}" ]] && [[ -f "${CONFIG_FILE}" ]]; then
        # shellcheck disable=SC1090
        source "${CONFIG_FILE}"
    fi
}

has_command() {
    command -v "$1" >/dev/null 2>&1
}

die() {
    echo "cl: $*" >&2
    exit 1
}

usage() {
    cat <<'EOF'
Usage:
    cl-new eks-<env> [-n <namespace>] [--k9s]
    cl-new ocp-<env> [-n <namespace>] [--k9s]

Examples:
    cl-new eks-test
    cl-new eks-test -n foo
    cl-new eks-test --k9s
    cl-new ocp-test
    cl-new ocp-test -n bar --k9s

Config:
    ~/.config/clusters.local

Required EKS config:
    CL_AWS_PROFILE_PREFIX
    CL_EKS_CLUSTER_NAME_TEMPLATE   (must contain {env})

Optional EKS config:
    CL_AWS_PROFILE_SEPARATOR       (default: -)
    CL_EKS_REGION                  (default: eu-north-1)

Optional OpenShift config:
    CL_OCP_SERVER
    CL_OCP_SERVER_<ENV>
EOF
}

require_command() {
    has_command "$1" || die "$1 not found"
}

env_suffix() {
    printf '%s' "$1" | tr '[:lower:]-' '[:upper:]_'
}

ocp_server_for_env() {
    local env="$1"
    local key
    key="CL_OCP_SERVER_$(env_suffix "${env}")"

    if [[ -n "${!key:-}" ]]; then
        printf '%s' "${!key}"
        return 0
    fi

    if [[ -n "${CL_OCP_SERVER:-}" ]]; then
        printf '%s' "${CL_OCP_SERVER}"
        return 0
    fi

    return 1
}

aws_profile_for_env() {
    local env="$1"
    local separator="${CL_AWS_PROFILE_SEPARATOR--}"

    [[ -n "${CL_AWS_PROFILE_PREFIX:-}" ]] || die "missing CL_AWS_PROFILE_PREFIX in ${CONFIG_FILE}"

    if [[ -z "${separator}" ]] || [[ "${CL_AWS_PROFILE_PREFIX}" == *"${separator}" ]]; then
        printf '%s' "${CL_AWS_PROFILE_PREFIX}${env}"
    else
        printf '%s' "${CL_AWS_PROFILE_PREFIX}${separator}${env}"
    fi
}

eks_cluster_name_for_env() {
    local env="$1"

    [[ -n "${CL_EKS_CLUSTER_NAME_TEMPLATE:-}" ]] || die "missing CL_EKS_CLUSTER_NAME_TEMPLATE in ${CONFIG_FILE}"
    [[ "${CL_EKS_CLUSTER_NAME_TEMPLATE}" == *"{env}"* ]] || die "CL_EKS_CLUSTER_NAME_TEMPLATE must contain {env}"

    printf '%s' "${CL_EKS_CLUSTER_NAME_TEMPLATE//\{env\}/${env}}"
}

run_assume() {
    local profile="$1"
    local assume_type=""
    local assume_path=""

    assume_type="$(type -t assume 2>/dev/null || true)"

    case "${assume_type}" in
        alias|function)
            assume "${profile}"
            return $?
            ;;
        file)
            assume_path="$(command -v assume 2>/dev/null || true)"
            if [[ -n "${assume_path}" ]] && [[ -r "${assume_path}" ]]; then
                # shellcheck disable=SC1090
                source "${assume_path}" "${profile}"
                return $?
            fi
            ;;
    esac

    if [[ -r "/opt/homebrew/bin/assume" ]]; then
        # shellcheck disable=SC1091
        source "/opt/homebrew/bin/assume" "${profile}"
        return $?
    fi

    die "'assume' not found. Install granted/assume or ensure it's loaded"
}

ensure_profile_ready() {
    local profile="$1"

    if aws sts get-caller-identity --profile "${profile}" >/dev/null 2>&1; then
        return 0
    fi

    aws sso login --profile "${profile}" || return $?
    aws sts get-caller-identity --profile "${profile}" >/dev/null 2>&1
}

select_context() {
    local context="$1"

    if has_command kubectx; then
        kubectx "${context}"
    else
        kubectl config use-context "${context}"
    fi
}

select_namespace() {
    local namespace="$1"

    if has_command kubens; then
        kubens "${namespace}"
    else
        kubectl config set-context --current --namespace="${namespace}" >/dev/null
    fi
}

start_k9s() {
    local namespace="$1"
    local namespace_explicit="$2"

    require_command k9s

    if [[ "${namespace_explicit}" == "1" ]]; then
        k9s -n "${namespace}"
    else
        k9s
    fi
}

login_eks() {
    local env="$1"
    local context="$2"
    local namespace="$3"
    local region="${CL_EKS_REGION:-eu-north-1}"
    local profile=""
    local cluster_name=""

    require_command aws
    require_command kubectl

    profile="$(aws_profile_for_env "${env}")"
    cluster_name="$(eks_cluster_name_for_env "${env}")"

    run_assume "${profile}" || return $?
    ensure_profile_ready "${profile}" || return $?

    aws eks update-kubeconfig \
        --profile "${profile}" \
        --region "${region}" \
        --name "${cluster_name}" \
        --alias "${context}" || return $?

    select_context "${context}" || return $?
    select_namespace "${namespace}" || return $?

    echo "cl: active context -> $(kubectl config current-context) (ns: ${namespace})"
}

login_ocp() {
    local env="$1"
    local context="$2"
    local namespace="$3"
    local server=""
    local current_context=""

    require_command oc
    require_command kubectl

    server="$(ocp_server_for_env "${env}")" || die "no OpenShift API endpoint configured for env '${env}'"

    oc login --server "${server}" --web || return $?

    current_context="$(kubectl config current-context 2>/dev/null)" || return $?
    kubectl config delete-context "${context}" >/dev/null 2>&1 || true
    kubectl config rename-context "${current_context}" "${context}" || return $?

    select_context "${context}" || return $?
    select_namespace "${namespace}" || return $?

    echo "cl: active context -> $(kubectl config current-context) (ns: ${namespace})"
}

parse_args() {
    TARGET=""
    NAMESPACE="default"
    NAMESPACE_EXPLICIT=0
    START_K9S=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -n|--namespace)
                shift
                [[ -n "${1:-}" ]] || die "missing value for -n/--namespace"
                NAMESPACE="$1"
                NAMESPACE_EXPLICIT=1
                shift
                ;;
            --k9s)
                START_K9S=1
                shift
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            --)
                shift
                break
                ;;
            -*)
                die "unknown option '$1'"
                ;;
            *)
                [[ -z "${TARGET}" ]] || die "unexpected argument '$1'"
                TARGET="$1"
                shift
                ;;
        esac
    done

    [[ -n "${TARGET}" ]] || {
        usage
        exit 2
    }
}

dispatch() {
    case "${TARGET}" in
        eks-*)
            login_eks "${TARGET#eks-}" "${TARGET}" "${NAMESPACE}"
            ;;
        ocp-*)
            login_ocp "${TARGET#ocp-}" "${TARGET}" "${NAMESPACE}"
            ;;
        *)
            die "unknown target '${TARGET}' (expected eks-* or ocp-*)"
            ;;
    esac
}

main() {
    load_local_config
    parse_args "$@"
    dispatch

    if [[ "${START_K9S}" == "1" ]]; then
        start_k9s "${NAMESPACE}" "${NAMESPACE_EXPLICIT}"
    fi
}

main "$@"
